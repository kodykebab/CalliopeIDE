# Server Configuration
PORT=5000
FLASK_ENV=development

# Database
DATABASE_URL=sqlite:///data/calliope.db

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# JWT Token Expiration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Gemini API (for AI agent)
GEMINI_API_KEY=your-gemini-api-key-here

# Monitoring & Error Tracking (Sentry)
# Backend monitoring (disabled by default)
ENABLE_MONITORING=false
SENTRY_DSN=your-backend-sentry-dsn-here
APP_VERSION=1.0.0

# Frontend monitoring (disabled by default)
NEXT_PUBLIC_ENABLE_MONITORING=false
NEXT_PUBLIC_SENTRY_DSN=your-frontend-sentry-dsn-here
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SENTRY_TUNNEL=
